# ActionPulse environment variables
# Copy to ~/.config/actionpulse/env and fill in real values.
#
# Format: KEY=value (no "export", no quotes)
# Works with: systemd EnvironmentFile=, bash "set -a && source"
#
# Setup:
#   mkdir -p ~/.config/actionpulse
#   cp deploy/env.example ~/.config/actionpulse/env
#   chmod 600 ~/.config/actionpulse/env

# === Required ===

EWS_PASSWORD=changeme
EWS_USER_UPN=your.login@corp-domain.ru
EWS_ENDPOINT=https://owa.corp-domain.ru/EWS/Exchange.asmx

LLM_TOKEN=changeme
LLM_ENDPOINT=https://llm-gw.corp.com/api/v1/chat

MM_WEBHOOK_URL=https://mm.corp.com/hooks/your-webhook-id

# === Optional ===

# DIGEST_CONFIG_PATH=/path/to/config.yaml
# DIGEST_OUT_DIR=/custom/out
# DIGEST_STATE_DIR=/custom/state
# DIGEST_LOG_LEVEL=INFO
